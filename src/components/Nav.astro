---
import { ACQUISITION_MAILTO, SITE } from '../config/site';
---

<nav id="nav" class="bg-slate-950/95 backdrop-blur-lg border-b border-slate-800 sticky top-0 z-50 transition-all">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="flex items-center justify-between h-20">
      <div class="flex items-center gap-x-3">
        <div class="flex items-center gap-x-2.5">
          <div class="w-9 h-9 bg-amber-500 rounded-xl flex items-center justify-center shadow-inner">
            <i class="fa-solid fa-globe text-slate-950 text-lg"></i>
          </div>
          <div>
            <span class="font-display text-2xl font-semibold tracking-tighter">languageleap</span>
            <span class="font-display text-2xl font-semibold tracking-tighter text-amber-400">english</span>
            <span class="text-xs font-mono text-slate-500 ml-1 align-super">.com</span>
          </div>
        </div>
      </div>

      <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
        <a href="#stats" class="hover:text-amber-400 transition-colors">The Numbers</a>
        <a href="#why" class="hover:text-amber-400 transition-colors">Why This Domain</a>
        <a href="#value" class="hover:text-amber-400 transition-colors">Perfect For</a>
      </div>

      <div class="flex items-center gap-x-3">
        <button onclick="showContactModal()"
                class="hidden sm:inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-2xl border border-slate-700 hover:bg-slate-900 transition-all active:scale-[0.985]">
          Make an Offer
        </button>
        <button onclick="initiatePurchase()"
                class="inline-flex items-center gap-x-2 px-6 py-2.5 text-sm font-semibold bg-amber-500 hover:bg-amber-600 active:bg-amber-700 text-slate-950 rounded-2xl transition-all shadow-lg shadow-amber-500/25 active:scale-[0.985]">
          <i class="fa-solid fa-shopping-cart mr-1.5"></i>
          <span>Acquire for $19,500</span>
        </button>
      </div>
    </div>
  </div>
</nav>
